<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Permitir tráfico HTTP sin cifrar (solo para desarrollo) -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Para emulador Android Studio -->
        <domain includeSubdomains="true">10.0.2.2</domain>

        <!-- Para localhost -->
        <domain includeSubdomains="true">localhost</domain>

        <!-- Añade tu IP local aquí si usas dispositivo real -->
        <!-- Ejemplo: <domain includeSubdomains="true">192.168.1.100</domain> -->
    </domain-config>

    <!-- Para producción, usa HTTPS -->
    <!-- <base-config cleartextTrafficPermitted="false" /> -->
</network-security-config>

